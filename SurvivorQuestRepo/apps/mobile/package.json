{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "dev": "cross-env EXPO_NO_DOCTOR=1 expo start",
    "start": "cross-env EXPO_NO_DOCTOR=1 expo start",
    "android": "cross-env EXPO_NO_DOCTOR=1 expo start --android",
    "ios": "cross-env EXPO_NO_DOCTOR=1 expo start --ios",
    "web": "cross-env EXPO_NO_DOCTOR=1 expo start --web",
    "build:apk": "npx eas-cli build --platform android --profile beta --wait",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "jest --ci --runInBand",
    "test:smoke": "jest --ci --runInBand --testPathPattern=smoke",
    "build:smoke": "cross-env EXPO_NO_DOCTOR=1 expo export --platform web --output-dir .expo-test-bundle-ci --clear"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~54.0.33",
    "expo-audio": "~1.1.1",
    "expo-camera": "^55.0.9",
    "expo-location": "~19.0.8",
    "expo-navigation-bar": "~5.0.10",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.2.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "0.2.2",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "5.6.1",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.16.1",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "3.4.17"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^54.0.10",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-expo": "^10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.13",
    "typescript": "~5.9.2"
  },
  "private": true
}
